# Frontend
VITE_API_BASE_URL=/api

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Optional alias for teams that name the key as SUPABASE_KEY.
# Code reads SUPABASE_SERVICE_ROLE_KEY first, then SUPABASE_KEY only if needed.
SUPABASE_KEY=

# Optional database connection string (currently not used by app runtime)
DATABASE_URL=

# AI model
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Server Configuration (Vercel)
PORT=5000
FLASK_ENV=production

